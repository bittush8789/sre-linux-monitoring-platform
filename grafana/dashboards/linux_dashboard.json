              {
                "color": "rgba(237, 129, 40, 0.4)",
                "value": 75
              },
              {
                "color": "rgba(245, 54, 54, 0.6)",
                "value": 90
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
