        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-sre"
          },
          "editorMode": "code",
          "expr": "node_load5{instance=~\"$instance\"}",
          "legendFormat": "5 min average",
          "refId": "B"
