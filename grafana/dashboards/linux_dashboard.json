          "editorMode": "code",
          "expr": "(1 - node_filesystem_avail_bytes{instance=~\"$instance\",fstype=~\"ext4|xfs|vfat\"} / node_filesystem_size_bytes{instance=~\"$instance\",fstype=~\"ext4|xfs|vfat\"}) * 100",
          "legendFormat": "{{mountpoint}} ({{fstype}})",
          "refId": "A"
